# ─── 0G Chain (Galileo testnet) ──────────────────────────────────────────────
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
# Public copies for client-side wallet/network add (optional; defaults match above)
NEXT_PUBLIC_OG_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_OG_CHAIN_ID=16602

# Deployed SkillMarketplace.sol address (from `npm run deploy:marketplace`)
NEXT_PUBLIC_SKILL_MARKETPLACE_ADDRESS=

# Platform key: contract admin + 0G Storage upload signer. Fund from https://faucet.0g.ai
PLATFORM_PRIVATE_KEY=0x...

# ─── 0G Storage ──────────────────────────────────────────────────────────────
OG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# ─── 0G Compute ──────────────────────────────────────────────────────────────
# direct = agent pays provider from its own wallet (most on-brand, but opening a
#          ledger requires a MINIMUM 3 0G in the payer wallet — see OG_LEDGER_MIN).
# router = OpenAI-compatible fallback with one API key (recommended for the demo
#          since the faucet only drips ~0.5 0G and 3 0G/agent is impractical).
OG_COMPUTE_MODE=router
OG_LEDGER_MIN=3
# Amount (in 0G) to top up the compute ledger with after it exists
OG_COMPUTE_FUND=0.1
# Router fallback (used when OG_COMPUTE_MODE=router) — get a key at https://pc.0g.ai
OG_ROUTER_URL=https://router-api.0g.ai/v1
OG_ROUTER_KEY=
OG_ROUTER_MODEL=llama-3.3-70b-instruct

# ─── Agent vault encryption (chain-agnostic, unchanged) ──────────────────────
AGENT_ENCRYPTION_KEY=   # 32-byte hex (openssl rand -hex 32)
SKILL_ENCRYPTION_KEY=   # 32-byte hex (openssl rand -hex 32)

# ─── Supabase (off-chain agent metadata vault) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
